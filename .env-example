PORT=3009
MONGODB_URI=mongodb://localhost:27017/dbname

# PostgreSQL (for auth, metrics, etc.) - use your macOS username for local dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tiwater_timeseries
POSTGRES_USER=luisfercordova
POSTGRES_PASSWORD=

TUYA_CLIENT_ID=your_client_id_here
TUYA_CLIENT_SECRET=your_client_secret_here
TUYA_ACCESS_TOKEN=your_access_token_here
TUYA_API_URL=https://openapi.tuyaus.com
TUYA_SIGN_METHOD=HMAC-SHA256
SECRET_KEY=your_secret_key

# Cron: Tuya logs routine (every 30 min). Use in Azure Logic Apps / Functions / external cron. Optional: CRON_DEV_MODE_SECRET or TIWATER_API_KEY also work.
# CRON_TUYA_LOGS_SECRET=your_cron_secret_here

# Email – used for password reset and metric alerts. See docs/EMAIL_CONFIG.md. Pick ONE option:
# (1) Disable: EMAIL_PROVIDER=none
# (2) SMTP password: EMAIL_PROVIDER=smtp, SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASSWORD
# (3) SMTP OAuth2 (2FA): EMAIL_PROVIDER=smtp, SMTP_AUTH_TYPE=oauth2, SMTP_USER, OAUTH_CLIENT_ID, OAUTH_CLIENT_SECRET, OAUTH_REFRESH_TOKEN (run scripts/get-oauth-refresh-token.js)
# (4) SendGrid: EMAIL_PROVIDER=sendgrid, SENDGRID_API_KEY, SENDGRID_FROM_EMAIL
# (5) Mailgun: EMAIL_PROVIDER=mailgun, MAILGUN_API_KEY, MAILGUN_DOMAIN, MAILGUN_FROM_EMAIL
# (6) Resend: EMAIL_PROVIDER=resend, RESEND_API_KEY, RESEND_FROM_EMAIL
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=soporte@lcc.com.mx
# SMTP_PASSWORD=

# MQTT Configuration (Mosquitto)
MQTT_BROKER=146.190.143.141
MQTT_PORT=1883
MQTT_CLIENT_ID=aquatech-api-consumer

# Azure Event Grid MQTT (optional - when migrating from Mosquitto)
# MQTT_BROKER=tiwatermqtt.eastus-1.eventgrid.azure.net
# MQTT_PORT=8883
# MQTT_USE_TLS=true
# MQTT_USERNAME=tiwater-api-consumer
# MQTT_CLIENT_ID=tiwater-api-consumer-session1
# MQTT_CLIENT_CERT_PATH=./certs/tiwater-api-consumer.pem
# MQTT_CLIENT_KEY_PATH=./certs/tiwater-api-consumer.key